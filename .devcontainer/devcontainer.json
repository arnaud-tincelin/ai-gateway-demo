{
  "name": "poc-genai-gateway-dev",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.13", "installTools": true },
    "ghcr.io/devcontainers/features/terraform:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/va-h/devcontainers-features/uv:1": { "shellautocompletion": true, "version": "latest" },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "hashicorp.terraform",
        "ms-vscode.azurecli",
        "ms-python.python",
				"ms-python.vscode-pylance",
				"GitHub.vscode-github-actions",
				"GitHub.copilot",
				"ms-azuretools.vscode-azure-github-copilot",
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": ".venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.analysis.typeCheckingMode": "basic",
        "terraform.telemetry.enabled": false
      }
    }
  },
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "mounts": [
    "source=terraform-plugin-cache,target=/home/vscode/.terraform.d/plugins,type=volume",
    // "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind"
  ],
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "forwardPorts": [],
  "updateContentCommand": "echo 'Devcontainer ready (features-based).'",
  "waitFor": "postCreateCommand",
  // "initializeCommand": "bash .devcontainer/init.sh"
}
